# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source files
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary

# Git
.gitattributes text eol=lf
.gitignore text eol=lf

# Lock files
package-lock.json text eol=lf
